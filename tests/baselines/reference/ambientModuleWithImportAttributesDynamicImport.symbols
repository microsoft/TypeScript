>wasmModule3 : Symbol(wasmModule3, Decl(test.ts, 34, 9))
>with : Symbol(with, Decl(test.ts, 34, 54))
>type : Symbol(type, Decl(test.ts, 34, 62))
>version : Symbol(version, Decl(test.ts, 34, 78))
>extra : Symbol(extra, Decl(test.ts, 34, 92))

    wasmModule3.default; // Should be any (no match - extra attribute)
>wasmModule3 : Symbol(wasmModule3, Decl(test.ts, 34, 9))
