>wasmModule2 : Symbol(wasmModule2, Decl(test.ts, 30, 9))
>with : Symbol(with, Decl(test.ts, 30, 54))
>type : Symbol(type, Decl(test.ts, 30, 62))

    wasmModule2.default; // Should be any (no match - missing version attribute)
>wasmModule2 : Symbol(wasmModule2, Decl(test.ts, 30, 9))

    // Should NOT resolve - extra attribute
