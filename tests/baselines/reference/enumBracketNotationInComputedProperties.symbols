>ConstType.Alpha : Symbol(ConstType.Alpha, Decl(enumBracketNotationInComputedProperties.ts, 37, 22))
>ConstType : Symbol(ConstType, Decl(enumBracketNotationInComputedProperties.ts, 34, 1))
>Alpha : Symbol(ConstType.Alpha, Decl(enumBracketNotationInComputedProperties.ts, 37, 22))

    [ConstType['Alpha']]: string;
>[ConstType['Alpha']] : Symbol([ConstType.Alpha], Decl(enumBracketNotationInComputedProperties.ts, 42, 21), Decl(enumBracketNotationInComputedProperties.ts, 43, 30))
>ConstType : Symbol(ConstType, Decl(enumBracketNotationInComputedProperties.ts, 34, 1))
>'Alpha' : Symbol(ConstType.Alpha, Decl(enumBracketNotationInComputedProperties.ts, 37, 22))

    [ConstType['2beta']]: number;
>[ConstType['2beta']] : Symbol([ConstType['2beta']], Decl(enumBracketNotationInComputedProperties.ts, 44, 33))
>ConstType : Symbol(ConstType, Decl(enumBracketNotationInComputedProperties.ts, 34, 1))
>'2beta' : Symbol(ConstType['2beta'], Decl(enumBracketNotationInComputedProperties.ts, 38, 20))
}

