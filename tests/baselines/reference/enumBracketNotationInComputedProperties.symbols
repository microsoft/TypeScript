//// [tests/cases/compiler/enumBracketNotationInComputedProperties.ts] ////

=== enumBracketNotationInComputedProperties.ts ===
// Test for issue #25083: Enum keys should be accepted as computed properties
// when using bracket notation

enum Type {
>Type : Symbol(Type, Decl(enumBracketNotationInComputedProperties.ts, 0, 0))

    Foo = 'foo',
>Foo : Symbol(Type.Foo, Decl(enumBracketNotationInComputedProperties.ts, 3, 11))

    Bar = 'bar',
>Bar : Symbol(Type.Bar, Decl(enumBracketNotationInComputedProperties.ts, 4, 16))

    '3x14' = '3x14', // Non-identifier name
>'3x14' : Symbol(Type['3x14'], Decl(enumBracketNotationInComputedProperties.ts, 5, 16))

    '0digit' = '0digit' // Starts with digit
>'0digit' : Symbol(Type['0digit'], Decl(enumBracketNotationInComputedProperties.ts, 6, 20))
}

// These should all work - dot notation (already works)
type TypeMapDot = {
>TypeMapDot : Symbol(TypeMapDot, Decl(enumBracketNotationInComputedProperties.ts, 8, 1))

    [Type.Foo]: string;
>[Type.Foo] : Symbol([Type.Foo], Decl(enumBracketNotationInComputedProperties.ts, 11, 19))
>Type.Foo : Symbol(Type.Foo, Decl(enumBracketNotationInComputedProperties.ts, 3, 11))
>Type : Symbol(Type, Decl(enumBracketNotationInComputedProperties.ts, 0, 0))
>Foo : Symbol(Type.Foo, Decl(enumBracketNotationInComputedProperties.ts, 3, 11))

    [Type.Bar]: number;
>[Type.Bar] : Symbol([Type.Bar], Decl(enumBracketNotationInComputedProperties.ts, 12, 23))
>Type.Bar : Symbol(Type.Bar, Decl(enumBracketNotationInComputedProperties.ts, 4, 16))
>Type : Symbol(Type, Decl(enumBracketNotationInComputedProperties.ts, 0, 0))
>Bar : Symbol(Type.Bar, Decl(enumBracketNotationInComputedProperties.ts, 4, 16))
}

// These should also work - bracket notation with identifier names
type TypeMapBracketIdentifier = {
>TypeMapBracketIdentifier : Symbol(TypeMapBracketIdentifier, Decl(enumBracketNotationInComputedProperties.ts, 14, 1))

    [Type['Foo']]: string;
>[Type['Foo']] : Symbol([Type['Foo']], Decl(enumBracketNotationInComputedProperties.ts, 17, 33))
>Type : Symbol(Type, Decl(enumBracketNotationInComputedProperties.ts, 0, 0))
>'Foo' : Symbol(Type.Foo, Decl(enumBracketNotationInComputedProperties.ts, 3, 11))

    [Type['Bar']]: number;
>[Type['Bar']] : Symbol([Type['Bar']], Decl(enumBracketNotationInComputedProperties.ts, 18, 26))
>Type : Symbol(Type, Decl(enumBracketNotationInComputedProperties.ts, 0, 0))
>'Bar' : Symbol(Type.Bar, Decl(enumBracketNotationInComputedProperties.ts, 4, 16))
}

// These should work - bracket notation with non-identifier names
// This is the main fix for #25083
type TypeMapBracketNonIdentifier = {
>TypeMapBracketNonIdentifier : Symbol(TypeMapBracketNonIdentifier, Decl(enumBracketNotationInComputedProperties.ts, 20, 1))

    [Type['3x14']]: boolean;
>[Type['3x14']] : Symbol([Type['3x14']], Decl(enumBracketNotationInComputedProperties.ts, 24, 36))
>Type : Symbol(Type, Decl(enumBracketNotationInComputedProperties.ts, 0, 0))
>'3x14' : Symbol(Type['3x14'], Decl(enumBracketNotationInComputedProperties.ts, 5, 16))

    [Type['0digit']]: object;
>[Type['0digit']] : Symbol([Type['0digit']], Decl(enumBracketNotationInComputedProperties.ts, 25, 28))
>Type : Symbol(Type, Decl(enumBracketNotationInComputedProperties.ts, 0, 0))
>'0digit' : Symbol(Type['0digit'], Decl(enumBracketNotationInComputedProperties.ts, 6, 20))
}

// Mixed usage should also work
type TypeMapMixed = {
>TypeMapMixed : Symbol(TypeMapMixed, Decl(enumBracketNotationInComputedProperties.ts, 27, 1))

    [Type.Foo]: string;
>[Type.Foo] : Symbol([Type.Foo], Decl(enumBracketNotationInComputedProperties.ts, 30, 21))
>Type.Foo : Symbol(Type.Foo, Decl(enumBracketNotationInComputedProperties.ts, 3, 11))
>Type : Symbol(Type, Decl(enumBracketNotationInComputedProperties.ts, 0, 0))
>Foo : Symbol(Type.Foo, Decl(enumBracketNotationInComputedProperties.ts, 3, 11))

    [Type['Bar']]: number;
>[Type['Bar']] : Symbol([Type['Bar']], Decl(enumBracketNotationInComputedProperties.ts, 31, 23))
>Type : Symbol(Type, Decl(enumBracketNotationInComputedProperties.ts, 0, 0))
>'Bar' : Symbol(Type.Bar, Decl(enumBracketNotationInComputedProperties.ts, 4, 16))

    [Type['3x14']]: boolean;
>[Type['3x14']] : Symbol([Type['3x14']], Decl(enumBracketNotationInComputedProperties.ts, 32, 26))
>Type : Symbol(Type, Decl(enumBracketNotationInComputedProperties.ts, 0, 0))
>'3x14' : Symbol(Type['3x14'], Decl(enumBracketNotationInComputedProperties.ts, 5, 16))
}

// Should work with const enums too
const enum ConstType {
>ConstType : Symbol(ConstType, Decl(enumBracketNotationInComputedProperties.ts, 34, 1))

    Alpha = 'alpha',
>Alpha : Symbol(ConstType.Alpha, Decl(enumBracketNotationInComputedProperties.ts, 37, 22))

    '2beta' = '2beta'
>'2beta' : Symbol(ConstType['2beta'], Decl(enumBracketNotationInComputedProperties.ts, 38, 20))
}

type ConstTypeMap = {
>ConstTypeMap : Symbol(ConstTypeMap, Decl(enumBracketNotationInComputedProperties.ts, 40, 1))

    [ConstType.Alpha]: string;
