// https://github.com/microsoft/TypeScript/issues/61259

const a = (v: 1 | 2) => {
>a : (v: 1 | 2) => 1 | 2
>  : ^ ^^     ^^^^^^^^^^
>(v: 1 | 2) => {  try {    switch (v) {      case 1:        return v;      case 2:        return v;    }  } finally {    console.log("exit");  }} : (v: 1 | 2) => 1 | 2
>                                                                                                                                                 : ^ ^^     ^^^^^^^^^^
>v : 1 | 2
>  : ^^^^^

  try {
    switch (v) {
>v : 1 | 2
>  : ^^^^^

      case 1:
>1 : 1
>  : ^

        return v;
>v : 1
>  : ^

      case 2:
>2 : 2
>  : ^

        return v;
>v : 2
>  : ^
    }
  } finally {
    console.log("exit");
>console.log("exit") : void
>                    : ^^^^
>console.log : (...data: any[]) => void
>            : ^^^^    ^^     ^^^^^    
>console : Console
>        : ^^^^^^^
>log : (...data: any[]) => void
>    : ^^^^    ^^     ^^^^^    
>"exit" : "exit"
>       : ^^^^^^
  }
};

