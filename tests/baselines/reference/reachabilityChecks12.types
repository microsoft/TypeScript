>  : ^ ^^     ^^^^^^^^^^
>(v: 1 | 2) => {  try {    switch (v) {      case 1:        return v;      case 2:        return v;    }  } finally {    if (Math.random()) {      console.log("exit");    }  }} : (v: 1 | 2) => 1 | 2
>                                                                                                                                                                                : ^ ^^     ^^^^^^^^^^
>v : 1 | 2
