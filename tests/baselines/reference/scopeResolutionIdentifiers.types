//// [tests/cases/conformance/expressions/identifiers/scopeResolutionIdentifiers.ts] ////

=== scopeResolutionIdentifiers.ts ===
// EveryType used in a nested scope of a different EveryType with the same name, type of the identifier is the one defined in the inner scope

var s: string;
>s : string
>  : ^^^^^^

namespace M1 {
>M1 : typeof M1
>   : ^^^^^^^^^

    export var s: number = 0;
>s : number
>  : ^^^^^^
>0 : 0
>  : ^

    var n = s;
>n : number
>  : ^^^^^^
>s : number
>  : ^^^^^^

    var n: number;
>n : number
>  : ^^^^^^
}

namespace M2 {
>M2 : typeof M2
>   : ^^^^^^^^^

    var s: number = 0;
>s : number
>  : ^^^^^^
>0 : 0
>  : ^

    var n = s;
>n : number
>  : ^^^^^^
>s : number
>  : ^^^^^^

    var n: number;
>n : number
>  : ^^^^^^
}

function fn() {
>fn : () => void
>   : ^^^^^^^^^^

    var s: boolean = false;
>s : boolean
>  : ^^^^^^^
>false : false
>      : ^^^^^

    var n = s;
>n : boolean
>  : ^^^^^^^
>s : false
>  : ^^^^^

    var n: boolean;
>n : boolean
>  : ^^^^^^^
}

class C {
>C : C
>  : ^

    s!: Date;
>s : Date
>  : ^^^^

    n = this.s;
>n : Date
>  : ^^^^
>this.s : Date
>       : ^^^^
>this : this
>     : ^^^^
>s : Date
>  : ^^^^

    x() {
>x : () => void
>  : ^^^^^^^^^^

        var p = this.n;
>p : Date
>  : ^^^^
>this.n : Date
>       : ^^^^
>this : this
>     : ^^^^
>n : Date
>  : ^^^^

        var p: Date;
>p : Date
>  : ^^^^
    }
}

namespace M3 {
>M3 : typeof M3
>   : ^^^^^^^^^

    var s: any;
>s : any

    namespace M4 {
>M4 : typeof M4
>   : ^^^^^^^^^

        var n = s;
>n : any
>s : any

        var n: any;
>n : any
    }
}

