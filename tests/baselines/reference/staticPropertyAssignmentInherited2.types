>this.value2 : number | undefined
>            : ^^^^^^^^^^^^^^^^^^
>this : typeof Derived
>     : ^^^^^^^^^^^^^^
>value2 : number | undefined
>       : ^^^^^^^^^^^^^^^^^^
>20 : 20
>   : ^^
>'' : ""
>   : ^^
    }
    this.value5 = {
>this.value5 = {      get [this.value3 = 30]() { return ''; }    } : {}
>                                                                  : ^^
>this.value5 : {} | undefined
>            : ^^^^^^^^^^^^^^
>this : typeof Derived
>     : ^^^^^^^^^^^^^^
>value5 : {} | undefined
>       : ^^^^^^^^^^^^^^
>{      get [this.value3 = 30]() { return ''; }    } : {}
>                                                    : ^^

      get [this.value3 = 30]() { return ''; }
>[this.value3 = 30] : string
