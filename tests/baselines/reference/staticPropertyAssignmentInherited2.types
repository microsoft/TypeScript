let v = Math.random() ? '' : 0;
>v : string | number
>  : ^^^^^^^^^^^^^^^
>Math.random() ? '' : 0 : "" | 0
>                       : ^^^^^^
>Math.random() : number
>              : ^^^^^^
>Math.random : () => number
>            : ^^^^^^      
>Math : Math
>     : ^^^^
>random : () => number
>       : ^^^^^^      
>'' : ""
>   : ^^
>0 : 0
>  : ^

class Base {
>Base : Base
>     : ^^^^

  static value1 = v;
>value1 : string | number
>       : ^^^^^^^^^^^^^^^
>v : string | number
>  : ^^^^^^^^^^^^^^^

  static value2 = v;
>value2 : string | number
>       : ^^^^^^^^^^^^^^^
>v : string | number
>  : ^^^^^^^^^^^^^^^

  static value3 = v;
>value3 : string | number
>       : ^^^^^^^^^^^^^^^
>v : string | number
>  : ^^^^^^^^^^^^^^^
}

class Derived extends Base {
>Derived : Derived
>        : ^^^^^^^
>Base : Base
>     : ^^^^

  static {
    this.value1 = 10;
>this.value1 = 10 : 10
>                 : ^^
>this.value1 : number | undefined
>            : ^^^^^^^^^^^^^^^^^^
>this : typeof Derived
>     : ^^^^^^^^^^^^^^
>value1 : number | undefined
>       : ^^^^^^^^^^^^^^^^^^
>10 : 10
>   : ^^

    this.value4 = {
>this.value4 = {      [this.value2 = 20]: ''    } : { 20: string; }
>                                                 : ^^^^^^^^^^^^^^^
>this.value4 : { 20: string; } | undefined
>            : ^^^^^^^^^^^^^^^^^^^^^^^^^^^
>this : typeof Derived
>     : ^^^^^^^^^^^^^^
>value4 : { 20: string; } | undefined
>       : ^^^^^^^^^^^^^^^^^^^^^^^^^^^
>{      [this.value2 = 20]: ''    } : { 20: string; }
>                                   : ^^^^^^^^^^^^^^^

      [this.value2 = 20]: ''
>[this.value2 = 20] : string
>                   : ^^^^^^
>this.value2 = 20 : 20
