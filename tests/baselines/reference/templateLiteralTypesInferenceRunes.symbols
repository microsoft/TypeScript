>C1 : Symbol(C1, Decl(templateLiteralTypesInferenceRunes.ts, 16, 33))
>C2 : Symbol(C2, Decl(templateLiteralTypesInferenceRunes.ts, 16, 44))

type C = Pair<"😀x">;
