>       : ^ ^^^^^^^^^^^^^^
>(a) => {    deferred(() => {        a;    });} : (a: any) => void
>                                              : ^ ^^^^^^^^^^^^^^
>a : any

    deferred(() => {
>deferred(() => {        a;    }) : void
>                                : ^^^^
>deferred : <T>(a: () => T) => T
>        : ^ ^^ ^^       ^^^^^ 
>() => {        a;    } : () => void
>                       : ^^^^^^^^^^

        a;
>a : any

    });
};
farrow(2);
>farrow(2) : void
>          : ^^^^
>farrow : (a: any) => void
>       : ^ ^^^^^^^^^^^^^^
>2 : 2
>  : ^

let prop1;
>prop1 : any

class C {
>C : C
>  : ^

    // Method declaration parameter
    method(a) {
>method : (a: any) => void
>       : ^ ^^^^^^^^^^^^^^
>a : any

        deferred(() => {
>deferred(() => {            a;        }) : void
>                                        : ^^^^
>deferred : <T>(a: () => T) => T
>        : ^ ^^ ^^       ^^^^^ 
>() => {            a;        } : () => void
>                               : ^^^^^^^^^^

            a;
>a : any

        });
    }
    // Accessor declaration parameter
    set x(v: number) {
>x : number
>  : ^^^^^^
>v : number
>  : ^^^^^^

        deferred(() => {
>deferred(() => {            v;        }) : void
>                                        : ^^^^
>deferred : <T>(a: () => T) => T
>        : ^ ^^ ^^       ^^^^^ 
>() => {            v;        } : () => void
>                               : ^^^^^^^^^^

            v;
>v : number
>  : ^^^^^^

        });
    }
    // in a property initializer
    p = deferred(() => {
>p : void
>  : ^^^^
>deferred(() => {        prop1;    }) : void
>                                    : ^^^^
>deferred : <T>(a: () => T) => T
>        : ^ ^^ ^^       ^^^^^ 
>() => {        prop1;    } : () => void
>                           : ^^^^^^^^^^

        prop1;
>prop1 : any

    });
}

new C();
>new C() : C
>        : ^
>C : typeof C
>  : ^^^^^^^^

