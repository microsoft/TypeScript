=== unusedLocalsAndParametersDeferred.ts ===
export { };

function deferred<T>(a: () => T): T {
>deferred : <T>(a: () => T) => T
>        : ^ ^^ ^^       ^^^^^ 
>a : () => T
>  : ^^^^^^ 

    return a();
>a() : T
>    : ^
>a : () => T
>  : ^^^^^^ 
}

// function declaration parameter
function f(a) {
>f : (a: any) => void
>  : ^ ^^^^^^^^^^^^^^
>a : any

    deferred(() => {
>deferred(() => {        a;    }) : void
>                                : ^^^^
>deferred : <T>(a: () => T) => T
>        : ^ ^^ ^^       ^^^^^ 
>() => {        a;    } : () => void
>                       : ^^^^^^^^^^

        a;
>a : any

    });
}
f(0);
>f(0) : void
>     : ^^^^
>f : (a: any) => void
>  : ^ ^^^^^^^^^^^^^^
>0 : 0
>  : ^

// function expression parameter
var fexp = function (a) {
>fexp : (a: any) => void
>     : ^ ^^^^^^^^^^^^^^
>function (a) {    deferred(() => {        a;    });} : (a: any) => void
>                                                    : ^ ^^^^^^^^^^^^^^
>a : any

    deferred(() => {
>deferred(() => {        a;    }) : void
>                                : ^^^^
>deferred : <T>(a: () => T) => T
>        : ^ ^^ ^^       ^^^^^ 
>() => {        a;    } : () => void
>                       : ^^^^^^^^^^

        a;
>a : any

    });
};
fexp(1);
>fexp(1) : void
>        : ^^^^
>fexp : (a: any) => void
>     : ^ ^^^^^^^^^^^^^^
>1 : 1
>  : ^

// arrow function parameter
var farrow = (a) => {
