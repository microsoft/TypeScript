>Inner : A2
>      : ^^

  type Wrapper<A extends any[]> = Inner<A, [...A, boolean, boolean, boolean]>;
>Wrapper : [...A, boolean, boolean, boolean]
>        : ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^
}

{
